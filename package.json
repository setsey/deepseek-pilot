{
  "name": "deepseek-pilot",
  "displayName": "DeepSeek Pilot — Vision + Token Tracking",
  "description": "DeepSeek V4 Pro & Flash in GitHub Copilot Chat. Vision proxy for image attachments, KV-cache-aware context-window indicator, persistent reasoning cache, live session cost and platform balance in the status bar, a thinking-effort selector per model variant, and one-click wiring as Copilot's utility/utility-small model.",
  "icon": "resources/icon.png",
  "version": "0.2.2",
  "publisher": "konstantyn-ganenkov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/setsey/deepseek-pilot.git"
  },
  "bugs": {
    "url": "https://github.com/setsey/deepseek-pilot/issues"
  },
  "homepage": "https://github.com/setsey/deepseek-pilot#readme",
  "sponsor": {
    "url": "https://github.com/sponsors/setsey"
  },
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "qna": "marketplace",
  "l10n": "./l10n",
  "engines": {
    "vscode": "^1.120.0",
    "node": ">=24"
  },
  "extensionDependencies": [
    "github.copilot-chat"
  ],
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "deepseek",
    "deepseek v4",
    "deepseek-v4",
    "copilot",
    "github copilot",
    "copilot chat",
    "vision",
    "token tracking",
    "balance",
    "byok",
    "language model",
    "thinking",
    "reasoning",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "deepseek-pilot",
        "displayName": "DeepSeek Pilot",
        "managementCommand": "deepseek-pilot.manage"
      }
    ],
    "commands": [
      {
        "command": "deepseek-pilot.manage",
        "title": "%deepseek-pilot.command.manage%"
      },
      {
        "command": "deepseek-pilot.setApiKey",
        "title": "%deepseek-pilot.command.setApiKey%"
      },
      {
        "command": "deepseek-pilot.getApiKey",
        "title": "%deepseek-pilot.command.getApiKey%"
      },
      {
        "command": "deepseek-pilot.clearApiKey",
        "title": "%deepseek-pilot.command.clearApiKey%"
      },
      {
        "command": "deepseek-pilot.setVisionModel",
        "title": "%deepseek-pilot.command.setVisionModel%"
      },
      {
        "command": "deepseek-pilot.showLogs",
        "title": "%deepseek-pilot.command.showLogs%"
      },
      {
        "command": "deepseek-pilot.refreshBalance",
        "title": "%deepseek-pilot.command.refreshBalance%"
      },
      {
        "command": "deepseek-pilot.clearSession",
        "title": "%deepseek-pilot.command.clearSession%"
      },
      {
        "command": "deepseek-pilot.showCacheStats",
        "title": "%deepseek-pilot.command.showCacheStats%"
      },
      {
        "command": "deepseek-pilot.showContextWindow",
        "title": "%deepseek-pilot.command.showContextWindow%"
      },
      {
        "command": "deepseek-pilot.setUtilityModel",
        "title": "%deepseek-pilot.command.setUtilityModel%"
      },
      {
        "command": "deepseek-pilot.setUtilitySmallModel",
        "title": "%deepseek-pilot.command.setUtilitySmallModel%"
      },
      {
        "command": "deepseek-pilot.clearReasoningCache",
        "title": "%deepseek-pilot.command.clearReasoningCache%"
      }
    ],
    "configuration": {
      "title": "%deepseek-pilot.config.title%",
      "properties": {
        "deepseek-pilot.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "%deepseek-pilot.config.baseUrl%"
        },
        "deepseek-pilot.maxTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%deepseek-pilot.config.maxTokens%"
        },
        "deepseek-pilot.reasoningEffort": {
          "type": "string",
          "enum": [
            "high",
            "max"
          ],
          "enumDescriptions": [
            "%deepseek-pilot.config.reasoningEffort.high%",
            "%deepseek-pilot.config.reasoningEffort.max%"
          ],
          "default": "max",
          "markdownDescription": "%deepseek-pilot.config.reasoningEffort%"
        },
        "deepseek-pilot.debug": {
          "type": "boolean",
          "default": false,
          "description": "%deepseek-pilot.config.debug%"
        },
        "deepseek-pilot.modelIdOverrides": {
          "type": "object",
          "default": {
            "deepseek-v4-flash": "deepseek-v4-flash",
            "deepseek-v4-pro": "deepseek-v4-pro"
          },
          "description": "%deepseek-pilot.config.modelIdOverrides%",
          "additionalProperties": false,
          "properties": {
            "deepseek-v4-flash": {
              "type": "string",
              "description": "%deepseek-pilot.config.modelIdOverrides.flash%"
            },
            "deepseek-v4-pro": {
              "type": "string",
              "description": "%deepseek-pilot.config.modelIdOverrides.pro%"
            }
          }
        },
        "deepseek-pilot.visionModel": {
          "type": "string",
          "default": "",
          "description": "%deepseek-pilot.config.visionModel%"
        },
        "deepseek-pilot.visionPrompt": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Describe the visual contents of this image in detail, including any text, objects, people, or context that would be relevant for understanding it. Focus on factual visual elements.",
          "description": "%deepseek-pilot.config.visionPrompt%"
        },
        "deepseek-pilot.contextWarnThreshold": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 95,
          "markdownDescription": "%deepseek-pilot.config.contextWarnThreshold%"
        },
        "deepseek-pilot.contextCriticalThreshold": {
          "type": "number",
          "default": 80,
          "minimum": 20,
          "maximum": 99,
          "markdownDescription": "%deepseek-pilot.config.contextCriticalThreshold%"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "deepseekPilotGettingStarted",
        "title": "%deepseek-pilot.walkthrough.title%",
        "description": "%deepseek-pilot.walkthrough.description%",
        "steps": [
          {
            "id": "setApiKey",
            "title": "%deepseek-pilot.walkthrough.step1.title%",
            "description": "%deepseek-pilot.walkthrough.step1.description%",
            "media": {
              "markdown": "resources/walkthrough/set-api-key.md"
            },
            "completionEvents": [
              "onCommand:deepseek-pilot.setApiKey"
            ]
          },
          {
            "id": "pickModel",
            "title": "%deepseek-pilot.walkthrough.step2.title%",
            "description": "%deepseek-pilot.walkthrough.step2.description%",
            "media": {
              "markdown": "resources/walkthrough/pick-model.md"
            }
          },
          {
            "id": "tuneReasoningEffort",
            "title": "%deepseek-pilot.walkthrough.step3.title%",
            "description": "%deepseek-pilot.walkthrough.step3.description%",
            "media": {
              "markdown": "resources/walkthrough/tune-effort.md"
            }
          },
          {
            "id": "support",
            "title": "%deepseek-pilot.walkthrough.step4.title%",
            "description": "%deepseek-pilot.walkthrough.step4.description%",
            "media": {
              "markdown": "resources/walkthrough/support.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "vscode:prepublish": "npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "npx oxlint",
    "format": "npx oxfmt --write src/",
    "package": "node scripts/package.mjs",
    "publish": "npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.120.0",
    "@vscode/vsce": "^3.9.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
